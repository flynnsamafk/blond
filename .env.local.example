# Copy this file to .env.local and fill in your Supabase project values.
# Project settings -> API in the Supabase dashboard.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this to the browser / NEXT_PUBLIC_*.
# Used later for seeding scripts and the Nano Banana server route.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI Style Mirror (Nano Banana / Gemini image model) ---------------------
# Server-only. Powers /api/apply-style. Get a free key:
#   https://aistudio.google.com/apikey
# Either GEMINI_API_KEY or GOOGLE_API_KEY is accepted. Restart the dev server
# after adding it. Without a key the mirror returns a clear "not configured"
# message instead of generating.
GEMINI_API_KEY=

# Optional. Override the image model (defaults to gemini-2.5-flash-image).
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# --- Grok Imagine (xAI image model) -----------------------------------------
# Server-only. Powers the "Grok Imagine Image (xAI)" option in the model picker
# (/api/try-on). Get a key at https://console.x.ai. Either XAI_API_KEY or
# GROK_API_KEY is accepted. Restart the dev server after adding it.
XAI_API_KEY=
